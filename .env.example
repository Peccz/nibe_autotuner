# ============================================================================
# Nibe Autotuner - Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values
# Required variables are marked with (REQUIRED)
# Optional variables have default values shown

# ============================================================================
# MyUplink API Credentials (REQUIRED)
# ============================================================================
# Get these from: https://dev.myuplink.com/apps
# 1. Register an account
# 2. Create a new OAuth2 application
# 3. Copy Client ID and Client Secret

MYUPLINK_CLIENT_ID=your_client_id_here
MYUPLINK_CLIENT_SECRET=your_client_secret_here
MYUPLINK_CALLBACK_URL=http://localhost:8080/oauth/callback

# MyUplink API URLs (defaults are correct, usually no need to change)
MYUPLINK_API_BASE_URL=https://api.myuplink.com
MYUPLINK_AUTH_URL=https://api.myuplink.com/oauth/authorize
MYUPLINK_TOKEN_URL=https://api.myuplink.com/oauth/token

# ============================================================================
# Home Assistant Integration (Optional but Recommended)
# ============================================================================
# Required for accurate indoor temperature readings from IKEA sensors
# If not provided, system will use Nibe's built-in sensor (BT50)

# HA_URL=http://homeassistant.local:8123
# HA_TOKEN=your_long_lived_access_token_here

# Home Assistant Sensor Entity IDs
# Update these to match your actual sensor entity IDs
HA_SENSOR_DOWNSTAIRS=sensor.timmerflotte_temp_hmd_sensor_temperature_2
HA_SENSOR_DEXTER=sensor.timmerflotte_temp_hmd_sensor_temperature

# ============================================================================
# House-Specific Physical Parameters
# ============================================================================
# These values should be calibrated for your specific installation

# Maximum temperature allowed into floor heating (°C)
# Prevents damage to floor heating system
SHUNT_LIMIT_C=32.0

# Heating curve set in your Nibe pump
# Typical values: 5.0-9.0 (higher = more aggressive heating)
DEFAULT_HEATING_CURVE=7.0

# ============================================================================
# SmartPlanner Calibration (Advanced)
# ============================================================================
# These are numerically calibrated values from real data
# Only change if you have collected data and performed calibration

# GM lost per degree-hour temperature difference
K_GM_PER_DELTA_T_PER_H=0.30

# Degrees Celsius gain per hour when compressor runs
COMPRESSOR_HEAT_OUTPUT_C_PER_H=0.18

# GM produced per hour when compressor is running
GM_PRODUCTION_PER_HOUR_RUNNING=60.0

# Outdoor temperature sensor correction (°C)
# Add this to weather forecast to match pump's outdoor sensor reading
OUTDOOR_TEMP_OFFSET_C=-0.5

# ============================================================================
# AI API Keys (Optional)
# ============================================================================
# Enable AI-powered optimization features

# Google Gemini API key for AI optimization
# Get from: https://makersuite.google.com/app/apikey
# GOOGLE_API_KEY=your_gemini_api_key_here

# Anthropic Claude API key (legacy, not actively used)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ============================================================================
# External Service APIs (Optional)
# ============================================================================

# Tibber API token for real-time electricity prices
# Get from: https://developer.tibber.com/
# TIBBER_API_TOKEN=your_tibber_token_here

# ============================================================================
# Database Configuration
# ============================================================================

# SQLite database location (default is fine for most use cases)
DATABASE_URL=sqlite:///./data/nibe_autotuner.db

# ============================================================================
# Application Server Configuration
# ============================================================================

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# FastAPI REST API server
API_SERVER_HOST=0.0.0.0
API_SERVER_PORT=8000

# Flask Mobile PWA dashboard
MOBILE_APP_HOST=0.0.0.0
MOBILE_APP_PORT=5001

# ============================================================================
# Quick Start Guide
# ============================================================================
# 1. Copy this file: cp .env.example .env
# 2. Edit .env and set at minimum:
#    - MYUPLINK_CLIENT_ID
#    - MYUPLINK_CLIENT_SECRET
# 3. (Optional but recommended) Set Home Assistant:
#    - HA_URL
#    - HA_TOKEN
# 4. Run authentication: python src/integrations/auth.py
# 5. Start data collection: python src/data/data_logger.py --interval 300
#
# For full setup instructions, see README.md
